{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "bundler",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2023",
    "module": "esnext",
    "lib": ["es2023", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "paths": {
      "@stustapay/components": ["./libs/components/src/index.ts"],
      "@stustapay/form-components": ["./libs/form-components/src/index.ts"],
      "@stustapay/framework": ["./libs/framework/src/index.ts"],
      "@stustapay/modal-provider": ["./libs/modal-provider/src/index.ts"],
      "@stustapay/models": ["./libs/models/src/index.ts"],
      "@stustapay/translations": ["./libs/translations/src/index.ts"],
      "@stustapay/utils": ["./libs/utils/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
